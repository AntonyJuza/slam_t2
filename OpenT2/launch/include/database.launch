<?xml version="1.0"?>
<launch>

    <arg name="OUTPUT_METHOD" default="screen"/>
    <arg name="RESPAWN" default="false"/>
    <arg name="ROBOT_TYPE" default="peanut"/>

    <node pkg="database" type="database_node" name="database" respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)">
        <param name="database_file_path" value="/etc/ros/runtime/database/peanut.db"/>
    </node>

</launch>
