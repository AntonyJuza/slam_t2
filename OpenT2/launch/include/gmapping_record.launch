<?xml version="1.0"?>

<launch>

    <!-- 必须手动创建相应的目录，否则bag执行不成功 -->
    <arg name="BAG_DIR" default="$(env HOME)/.ros/bag"/>
    <arg name="BAG_NAME" default="GmappingRecord"/>

    <arg name="diffname" default="O" />
    <arg name="OUTPUT_METHOD" default="screen"/>
    <arg name="RESPAWN" default="true"/>
    <arg name="ROBOT_TYPE" default="peanut"/>

    <node name="rosbag_record" pkg="rosbag" type="record" args="record /scan /tf /joy /gmapping_location_label -$(arg diffname) $(arg BAG_DIR)/$(arg BAG_NAME) " respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)">
    </node>

</launch>
