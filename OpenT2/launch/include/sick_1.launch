<?xml version="1.0"?>
<launch>

    <arg name="OUTPUT_METHOD" default="screen"/>
    <arg name="RESPAWN" default="false"/>
    <arg name="ROBOT_TYPE" default="peanut"/>

   <node name="sick_tim571" pkg="sick_tim" type="sick_tim551_2050001" respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)">
        <rosparam file="$(find robot_settings)/cfg/yaml/$(arg ROBOT_TYPE)/sick_tim571_params.yaml" command="load"/>
        <remap from="scan" to="scan_orig"/>
    </node>
</launch>
