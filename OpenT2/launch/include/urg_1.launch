<?xml version="1.0"?>

<launch>

    <arg name="OUTPUT_METHOD" default="screen"/>
    <arg name="RESPAWN" default="false"/>
    <arg name="ROBOT_TYPE" default="peanut"/>

    <node name="urg_node" pkg="urg_node" type="urg_node" respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)">
        <remap from="scan" to="scan_orig"/>
        <rosparam file="$(find robot_settings)/cfg/yaml/$(arg ROBOT_TYPE)/urg_params.yaml" command="load"/>
    </node>
</launch>
