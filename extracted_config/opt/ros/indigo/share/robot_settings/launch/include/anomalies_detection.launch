<?xml version="1.0"?>

<launch>

    <arg name="OUTPUT_METHOD" default="screen"/>
    <arg name="RESPAWN" default="false"/>
    <arg name="ROBOT_TYPE" default="peanut"/>
    <arg name="CAMERA_TYPE" default="None"/>
    <param name="camera_type" type="string" value="$(arg CAMERA_TYPE)"/>
    
    <node pkg="anomalies_detection" type="depth_laser_cali_node" name="depth_laser_cali_node" respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)">
    </node>

    <node pkg="anomalies_detection" type="sensor_monitor_node" name="sensor_monitor_node" respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)">
    </node>

</launch>
