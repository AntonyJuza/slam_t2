<?xml version="1.0"?>

<launch>

    <arg name="OUTPUT_METHOD" default="screen"/>
    <arg name="RESPAWN" default="false"/>
    <arg name="ROBOT_TYPE" default="peanut"/>
    <arg name="map_yaml_path" default="$(find robot_settings)/sim/world/keenonfixed.yaml"/>
    <arg name="map_topic" default="map"/>

    <node name="$(arg map_topic)_server" pkg="map_server" type="map_server" args="$(arg map_yaml_path)" respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)">
        <remap from="map" to="$(arg map_topic)"/>
        <remap from="static_map" to="static_$(arg map_topic)"/>
    </node>
</launch>
