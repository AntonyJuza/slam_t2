<?xml version="1.0"?>

<launch>

    <arg name="OUTPUT_METHOD" default="screen"/>
    <arg name="RESPAWN" default="false"/>
    <arg name="ROBOT_TYPE" default="peanut"/>

    <node name="switch_map" pkg="switch_map" type="switch_map" respawn="$(arg RESPAWN)" output="$(arg OUTPUT_METHOD)"/>
</launch>
